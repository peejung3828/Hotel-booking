# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://your-domain.com          # Public URL (used in LINE Pay callbacks, LIFF redirects)
APP_NAME=Hotel Booking System

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hotel_booking

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480          # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LINE Messaging API ─────────────────────────────────────────────────────────
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LIFF_ID=your_liff_id                    # e.g. 1234567890-AbCdEfGh

# ── LINE Pay ───────────────────────────────────────────────────────────────────
LINE_PAY_CHANNEL_ID=your_line_pay_channel_id
LINE_PAY_CHANNEL_SECRET=your_line_pay_channel_secret
LINE_PAY_SANDBOX=true                   # Set to false in production

# ── Bank transfer info (shown on payment page) ─────────────────────────────────
BANK_NAME=ธนาคารกสิกรไทย
BANK_ACCOUNT_NAME=ชื่อบัญชีที่พัก
BANK_ACCOUNT_NUMBER=000-0-00000-0

# ── Omise (card / PromptPay payments) ─────────────────────────────────────────
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_SECRET_KEY=skey_test_...

# ── File uploads ───────────────────────────────────────────────────────────────
UPLOAD_DIR=backend/static/uploads
MAX_IMAGE_WIDTH=1200
MAX_IMAGE_HEIGHT=800

# ── Email Reports (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password       # Gmail: use App Password (not login password)
SMTP_TLS=true
SMTP_SSL=false
SMTP_FROM=Hotel Reports <your_email@gmail.com>
REPORT_EMAIL=owner@example.com        # Email address to receive monthly reports
